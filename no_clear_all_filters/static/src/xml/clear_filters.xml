<templates xml:space="preserve">

    <!-- Extend the SearchBar template to add a Clear All button -->
    <t t-name="no_clear_all_filters.SearchBar" t-inherit="web.SearchBar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_cp_searchview')]" position="inside">
            <button t-if="hasActiveFilters"
                    class="btn btn-outline-danger o_no_clear_all_filters_btn d-print-none"
                    t-on-click="clearAllFilters"
                    title="Clear all active filters, group-bys, and favorites">
                <i class="fa fa-times-circle me-1"/>Clear All
            </button>
        </xpath>
    </t>

</templates>
